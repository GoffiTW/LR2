<UserControl x:Class="Привязка_и_команды.Views.OneTimeBindingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="0,10">
            <Border Style="{StaticResource SectionStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Margin="0,0,15,0">
                        <TextBlock FontSize="16" FontWeight="Bold" Text="OneTime (ViewModel)" Margin="0,0,0,10"/>
                        <TextBlock FontSize="22" FontWeight="Bold" Text="{Binding SessionCode, Mode=OneTime}"/>
                        <TextBlock Text="{Binding SessionCode, StringFormat=OneWay: {0}}" Margin="0,10,0,0" FontSize="11"/>
                        <TextBlock Text="{Binding CurrentTime, StringFormat=Время: {0}}" Foreground="Gray" FontSize="11"/>
                        <Button Content="Сгенерировать" Command="{Binding GenerateSessionCodeCommand}" Margin="0,15,0,0" Width="120"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="15,0,0,0">
                        <TextBlock FontSize="16" FontWeight="Bold" Text="OneTime (элемент)" Margin="0,0,0,10"/>
                        <TextBox x:Name="SourceBox" Text="Начальное значение"/>
                        <TextBlock Text="{Binding ElementName=SourceBox, Path=Text, Mode=OneTime}" 
                                   FontWeight="SemiBold" Margin="0,10,0,5"/>
                        <TextBlock Text="{Binding ElementName=SourceBox, Path=Text, Mode=OneWay, StringFormat=OneWay: {0}}" 
                                   FontSize="11" Foreground="Gray"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Style="{StaticResource SectionStyle}" Background="#FFF9E6">
                <TextBlock Text="Примечание: OneTime читает значение только один раз, OneWay обновляется автоматически" 
                           FontSize="11" Foreground="#856404"/>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>