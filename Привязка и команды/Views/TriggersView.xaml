<UserControl x:Class="Привязка_и_команды.Views.TriggersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <Style x:Key="TriggerCardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Margin" Value="0,0,8,8"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F0F8FF"/>
                    <Setter Property="BorderBrush" Value="#0078D4"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DataTriggerCardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Margin" Value="8,0,0,8"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsDangerMode}" Value="True">
                    <Setter Property="Background" Value="#FFE6E6"/>
                    <Setter Property="BorderBrush" Value="#D32F2F"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="MultiTriggerCardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Margin" Value="0,8,8,0"/>
            <Style.Triggers>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding IsDangerMode}" Value="True"/>
                        <Condition Binding="{Binding SelectedTriggerItem}" Value="Критический"/>
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Background" Value="#FFCCCC"/>
                    <Setter Property="BorderBrush" Value="#D32F2F"/>
                    <Setter Property="BorderThickness" Value="2"/>
                </MultiDataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="EventTriggerCardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Margin" Value="8,8,0,0"/>
            <Style.Triggers>
                <EventTrigger RoutedEvent="MouseEnter">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                             From="0.7" To="1" Duration="0:0:0.2"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="0,10">
            <!-- Управление -->
            <Border Style="{StaticResource SectionStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Margin="0,0,15,0">
                        <TextBlock FontSize="16" FontWeight="Bold" Text="Управление" Margin="0,0,0,10"/>
                        <CheckBox Content="Опасный режим" IsChecked="{Binding IsDangerMode}"/>
                        <TextBlock Text="Тип элемента:" Margin="0,15,0,5"/>
                        <ComboBox ItemsSource="{Binding TriggerItems}" 
                                  SelectedItem="{Binding SelectedTriggerItem}" Width="150"/>
                        <TextBlock Text="Уровень:" Margin="0,15,0,5"/>
                        <Slider Minimum="0" Maximum="100" Value="{Binding TriggerLevel}"/>
                        <TextBlock Text="{Binding TriggerLevel, StringFormat=Значение: {0}}" Margin="0,5,0,0"/>
                        <Button Content="Переключить" Command="{Binding ToggleDangerCommand}" Margin="0,20,0,0" Width="100"/>
                    </StackPanel>

                    <Border Grid.Column="1" Background="#F5F5F5" BorderBrush="#E0E0E0" 
                            BorderThickness="1" CornerRadius="4" Padding="10">
                        <StackPanel>
                            <TextBlock FontSize="14" FontWeight="Bold" Text="Состояние" Margin="0,0,0,10"/>
                            <TextBlock Text="{Binding IsDangerMode, StringFormat=Опасный режим: {0}}" Margin="0,3"/>
                            <TextBlock Text="{Binding SelectedTriggerItem, StringFormat=Тип: {0}}" Margin="0,3"/>
                            <TextBlock Text="{Binding TriggerLevel, StringFormat=Уровень: {0}}" Margin="0,3"/>
                            <ProgressBar Value="{Binding TriggerLevel}" Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- Примеры триггеров -->
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource TriggerCardStyle}">
                    <StackPanel>
                        <TextBlock FontSize="14" FontWeight="Bold" Text="Trigger"/>
                        <TextBlock Text="Срабатывает при наведении мыши" FontSize="11" Foreground="Gray" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource DataTriggerCardStyle}">
                    <StackPanel>
                        <TextBlock FontSize="14" FontWeight="Bold" Text="DataTrigger"/>
                        <TextBlock Text="Срабатывает при включении опасного режима" FontSize="11" Foreground="Gray" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource MultiTriggerCardStyle}">
                    <StackPanel>
                        <TextBlock FontSize="14" FontWeight="Bold" Text="MultiDataTrigger"/>
                        <TextBlock Text="Срабатывает: опасный режим + критический тип" FontSize="11" Foreground="Gray" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource EventTriggerCardStyle}">
                    <StackPanel>
                        <TextBlock FontSize="14" FontWeight="Bold" Text="EventTrigger"/>
                        <TextBlock Text="Запускает анимацию при наведении" FontSize="11" Foreground="Gray" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>