<UserControl x:Class="Привязка_и_команды.Views.DefaultBindingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="0,10">
            <!-- Прямая привязка -->
            <Border Style="{StaticResource SectionStyle}">
                <StackPanel>
                    <TextBlock FontSize="16" FontWeight="Bold" Text="Прямая привязка (ElementName)" Margin="0,0,0,10"/>
                    <Slider x:Name="SizeSlider" Minimum="12" Maximum="26" Value="18" Width="300"/>
                    <TextBlock Text="Размер меняется" FontWeight="SemiBold"
                               FontSize="{Binding ElementName=SizeSlider, Path=Value}"
                               Margin="0,10"/>
                    <TextBlock Text="{Binding ElementName=SizeSlider, Path=Value, StringFormat=Значение: {0:F0}px}" 
                               FontSize="11" Foreground="Gray"/>
                </StackPanel>
            </Border>

            <!-- Через ViewModel -->
            <Border Style="{StaticResource SectionStyle}">
                <StackPanel>
                    <TextBlock FontSize="16" FontWeight="Bold" Text="Привязка к ViewModel" Margin="0,0,0,10"/>
                    <TextBlock Text="Текст:"/>
                    <TextBox Text="{Binding DefaultInput}"/>
                    <TextBlock Text="{Binding DefaultInput}" FontWeight="SemiBold" Margin="0,8,0,0"/>
                    <TextBlock Text="{Binding DefaultNote}" Foreground="Gray" Margin="0,4,0,8"/>
                    <Button Content="Сбросить" Command="{Binding ResetDefaultCommand}" Width="100"/>
                </StackPanel>
            </Border>

            <!-- Счетчик команд -->
            <Border Style="{StaticResource SectionStyle}">
                <TextBlock Text="{Binding CommandCount, StringFormat=Выполнено команд: {0}}" FontWeight="SemiBold"/>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>