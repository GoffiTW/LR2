<UserControl x:Class="Привязка_и_команды.Views.OneWayBindingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="0,10">
            <!-- OneWay -->
            <Border Background="White" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="6" Padding="15" Margin="0,0,0,15">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Margin="0,0,15,0">
                        <TextBlock FontSize="16" FontWeight="Bold" Text="OneWay" Margin="0,0,0,10"/>
                        <ProgressBar Value="{Binding Progress, Mode=OneWay}" Height="6"/>
                        <TextBlock Text="{Binding Progress, StringFormat=Прогресс: {0}%}" Margin="0,8,0,0"/>
                        <TextBlock Text="{Binding OneWayText}" FontWeight="SemiBold" Margin="0,5,0,10"/>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="+" Command="{Binding IncreaseProgressCommand}" Width="40"/>
                            <Button Content="-" Command="{Binding DecreaseProgressCommand}" Width="40"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="15,0,0,0">
                        <TextBlock FontSize="16" FontWeight="Bold" Text="OneWayToSource" Margin="0,0,0,10"/>
                        <TextBox Text="{Binding SourceFromTarget, Mode=OneWayToSource, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Text="{Binding SourceFromTarget, StringFormat=Источник: {0}}" Margin="0,8,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- UpdateSourceTrigger -->
            <Border Background="White" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="6" Padding="15" Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock FontSize="16" FontWeight="Bold" Text="UpdateSourceTrigger" Margin="0,0,0,10"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Margin="0,0,15,0">
                            <TextBlock Text="PropertyChanged" FontWeight="SemiBold" FontSize="12"/>
                            <TextBox Text="{Binding UpdateOnPropertyChanged, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBlock Text="{Binding UpdateOnPropertyChanged, StringFormat=Источник: {0}}" FontSize="11" Foreground="Gray"/>

                            <TextBlock Text="LostFocus" FontWeight="SemiBold" FontSize="12" Margin="0,15,0,0"/>
                            <TextBox Text="{Binding UpdateOnLostFocus, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"/>
                            <TextBlock Text="{Binding UpdateOnLostFocus, StringFormat=Источник: {0}}" FontSize="11" Foreground="Gray"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="15,0,0,0">
                            <TextBlock Text="Explicit" FontWeight="SemiBold" FontSize="12"/>
                            <TextBox x:Name="ExplicitBox" Text="{Binding UpdateExplicit, Mode=TwoWay, UpdateSourceTrigger=Explicit}"/>
                            <Button Content="Обновить источник" Command="{Binding ApplyExplicitBindingCommand}" 
                                    CommandParameter="{Binding ElementName=ExplicitBox}" Margin="0,8,0,0" Width="120"/>
                            <TextBlock Text="{Binding UpdateExplicit, StringFormat=Источник: {0}}" FontSize="11" Foreground="Gray" Margin="0,8,0,0"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Прямая OneWay -->
            <Border Background="White" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="6" Padding="15" Margin="0,0,0,0">
                <StackPanel>
                    <TextBlock FontSize="14" FontWeight="Bold" Text="Прямая OneWay-привязка" Margin="0,0,0,10"/>
                    <Slider x:Name="WidthSlider" Minimum="50" Maximum="300" Value="150"/>
                    <Rectangle Height="30" Fill="#0078D4" Width="{Binding ElementName=WidthSlider, Path=Value}" RadiusX="3" RadiusY="3" Margin="0,10,0,0"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>