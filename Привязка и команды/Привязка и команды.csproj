<Project Sdk="Microsoft.NET.Sdk">
	<PropertyGroup>
		<!-- Тип выходного файла - исполняемое приложение Windows -->
		<OutputType>WinExe</OutputType>
		<!-- Целевая платформа - .NET Framework 4.8 -->
		<TargetFramework>net48</TargetFramework>
		<!-- Язык WPF для использования контролов -->
		<UseWPF>true</UseWPF>

		<!-- Явно устанавливаем язык C# в последнюю доступную версию -->
		<LangVersion>latest</LangVersion>
		<!-- Дополнительные флаги для совместимости -->
		<Nullable>enable</Nullable>
		<ImplicitUsings>disable</ImplicitUsings>
		<GenerateAssemblyInfo>false</GenerateAssemblyInfo>
	</PropertyGroup>

	<!-- Ссылка на WPF-дизайнер для совместимости -->
	<ItemGroup>
		<PackageReference Include="CommunityToolkit.Mvvm" Version="8.4.2" />
		<PackageReference Include="Microsoft.Windows.Compatibility" Version="8.0.0" />
	</ItemGroup>

	<!-- Настройка для запуска приложения -->
	<PropertyGroup>
		<StartupObject>Привязка_и_команды.App</StartupObject>
	
	</PropertyGroup>
	
</Project>