<Window x:Class="Привязка_и_команды.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:Привязка_и_команды.Views"
        Title="Лабораторная работа №2 - Привязки и команды" 
        Height="650" Width="900"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <TabControl>
            <TabItem Header="По умолчанию">
                <views:DefaultBindingView />
            </TabItem>
            <TabItem Header="Двухсторонняя">
                <views:TwoWayBindingView />
            </TabItem>
            <TabItem Header="Одноразовая">
                <views:OneTimeBindingView />
            </TabItem>
            <TabItem Header="Односторонние">
                <views:OneWayBindingsView />
            </TabItem>
            <TabItem Header="Триггеры">
                <views:TriggersView />
            </TabItem>
        </TabControl>
    </Grid>
</Window>